        <a href="DashboardServlet" class="elite-nav-link">
            <i class="fa-solid fa-arrow-left"></i> Main Dashboard
        </a>
    </nav>
    
    <div class="position-absolute bottom-0 w-100 p-3 border-top border-secondary border-opacity-25">
