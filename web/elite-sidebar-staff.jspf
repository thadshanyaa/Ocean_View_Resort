<div class="elite-sidebar" style="background: #020617; border-right: 1px solid rgba(234, 179, 8, 0.2);">
    <div class="p-4 mb-4">
        <h4 class="fw-bold text-gold m-0">ELITE MONITOR</h4>
        <small class="text-white-50">${user.role} Control</small>
    </div>
    
    <nav>
        <div class="px-4 mb-2 small text-uppercase text-gold opacity-50 fw-bold" style="letter-spacing: 1px;">Operations</div>
        <a href="elite-staff-view" class="elite-nav-link active">
            <i class="fa-solid fa-list-check"></i> Elite Bookings
